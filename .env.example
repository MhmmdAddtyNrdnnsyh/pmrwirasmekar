# Salin file ini menjadi .env dan isi nilainya.
# Jangan commit .env yang sudah terisi credential!

# ─── Google Sheets API ─────────────────────────────────────────────
# Buat Service Account, aktifkan Google Sheets API, lalu share Sheet
# ke GOOGLE_SHEETS_CLIENT_EMAIL sebagai Editor.
GOOGLE_SHEETS_SPREADSHEET_ID=""
GOOGLE_SHEETS_CLIENT_EMAIL=""
# Bisa pakai format satu baris dengan \n dari Google credential JSON.
GOOGLE_SHEETS_PRIVATE_KEY=""

# Nama sheet (tab) untuk masing-masing data
GOOGLE_SHEETS_ADMIN_SHEET="Admin"
GOOGLE_SHEETS_PENDAFTARAN_SHEET="Pendaftaran"
GOOGLE_SHEETS_ARTIKEL_SHEET="Artikel"
GOOGLE_SHEETS_KEGIATAN_SHEET="Kegiatan"
GOOGLE_SHEETS_PENGURUS_SHEET="Pengurus"

# Link grup WhatsApp yang muncul setelah pendaftaran berhasil
NEXT_PUBLIC_WHATSAPP_GROUP_URL="https://chat.whatsapp.com/..."

# ─── Supabase Storage (untuk upload foto/thumbnail) ────────────────
# Dapatkan dari Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="pmr-assets"

# ─── NextAuth / Auth.js ────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Di production isi dengan domain Vercel (contoh: https://pmr.vercel.app)
# Saat dev, biarkan kosong — otomatis ke http://localhost:3000

# ─── Seeder admin (opsional, kalau ingin override default) ─────────
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD=""
