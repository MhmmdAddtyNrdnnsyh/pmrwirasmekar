# Salin file ini menjadi .env dan isi nilainya.
# Jangan commit .env yang sudah terisi credential!

# ─── Supabase / Prisma ──────────────────────────────────────────────
# Dapatkan dari Supabase Dashboard → Settings → Database → Connection String

# Untuk Next.js runtime (pakai PgBouncer connection pooling di Vercel)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?pgbouncer=true"

# Untuk Prisma migrate & generate (koneksi langsung tanpa pooling)
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ─── Supabase Storage (untuk upload foto/thumbnail) ────────────────
# Dapatkan dari Supabase Dashboard → Settings → API
# Bucket: pmr_wira_smekar_storage (public)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""

# ─── NextAuth / Auth.js ────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=""

# Di production isi dengan domain Vercel (contoh: https://pmr.vercel.app)
# Saat dev, biarkan kosong — otomatis ke http://localhost:3000
AUTH_URL=""

# ─── Seeder admin (opsional, kalau ingin override default) ─────────
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD=""
